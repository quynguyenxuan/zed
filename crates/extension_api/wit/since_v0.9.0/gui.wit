package zed:extension;

interface gui {

    use ui-elements.{ui-tree};

    // ── Theme ─────────────────────────────────────────────────────────────

    // RGBA color used for theme color values delivered to the extension.
    record color { r: u8, g: u8, b: u8, a: u8 }

    record theme-colors {
        background:                  color,
        editor-background:           color,
        surface-background:          color,
        elevated-surface-background: color,
        text:                        color,
        text-muted:                  color,
        text-disabled:               color,
        text-accent:                 color,
        border:                      color,
        border-muted:                color,
        border-focused:              color,
        element-background:          color,
        element-hover:               color,
        element-selected:            color,
        element-active:              color,
        element-disabled:            color,
        panel-background:            color,
        status-error:                color,
        status-warning:              color,
        status-success:              color,
        status-info:                 color,
    }

    record theme {
        name:    string,
        is-dark: bool,
        colors:  theme-colors,
    }

    // ── Events ────────────────────────────────────────────────────────────

    record mouse-event-data {
        x:           f32,
        y:           f32,
        // 0=left, 1=right, 2=middle
        button:      u8,
        click-count: u32,
        shift:       bool,
        ctrl:        bool,
        alt:         bool,
        meta:        bool,
    }

    record key-event-data {
        // Key name, e.g. "Enter", "a", "ArrowDown".
        key:    string,
        shift:  bool,
        ctrl:   bool,
        alt:    bool,
        meta:   bool,
        repeat: bool,
    }

    record scroll-event-data {
        delta-x: f32,
        delta-y: f32,
        // true when coming from a trackpad (precise scrolling).
        precise: bool,
    }

    variant ui-event {
        // Mouse
        clicked(mouse-event-data),
        double-clicked(mouse-event-data),
        right-clicked(mouse-event-data),
        mouse-down(mouse-event-data),
        mouse-up(mouse-event-data),
        mouse-moved(mouse-event-data),
        // Hover
        hover-start,
        hover-end,
        // Scroll
        scroll-wheel(scroll-event-data),
        // Keyboard
        key-down(key-event-data),
        key-up(key-event-data),
        // Focus
        focus-gained,
        focus-lost,
        // Input element value changed.
        input-changed(string),
        // Drag/drop
        drag-started,
        // Serialized drag payload.
        dropped(string),
    }

    // ── Host functions (provided by Zed, called by WASM) ─────────────────

    /// Creates a focus handle managed by the host. Returns an opaque integer
    /// ID. Pass it in div-node.focus-handle-id to make that element focusable.
    create-focus-handle: func() -> u32;

    /// Requests keyboard focus for the given focus handle.
    request-focus: func(handle-id: u32);

    /// Releases focus handle resources when no longer needed.
    drop-focus-handle: func(handle-id: u32);

    /// Emits a named event to Zed for forwarding to the extension's logic callbacks.
    emit: func(name: string, data: string);

    /// Requests data from the host; the result is delivered via the gui-on-data export.
    request-data: func(key: string);

    /// Dispatches a named host action asynchronously.
    /// The result is delivered via gui-on-data(key, result-json).
    /// Returns an error immediately if the method name is not in the allowed set.
    call: func(key: string, method: string, params: string) -> result<_, string>;


}
